  champions:
  - characterName: PULSE RUNNER
    traits: THE CORE BEAT
    characterAnimator: {fileID: 9100000, guid: 2f930b09ab552264e8e4187a8dfb4a8e, type: 2}
    nameColor: {r: 0.9490197, g: 0.8588236, b: 0.48235297, a: 1}
    titleColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
    traitsColor: {r: 0.5764706, g: 0.83137256, b: 1, a: 1}
    backgroundSprite: {fileID: -3199277004969739004, guid: c7e6c941c4c48e34997b7d7b3eb666f4, type: 3}
    rotatingCircleSprite: {fileID: -6559999109497311705, guid: d01330c6a5e776a45a8621f2df0b40a3, type: 3}
    profile:
      speedValue: 75
      speedTextColor: {r: 0.5764706, g: 0.8313726, b: 1, a: 1}
      progressFill: {fileID: 128680841}
      fillColor: {r: 1, g: 0.9215687, b: 0.015686275, a: 1}
    story:
      storyText: "Khi The Silence \u1EADp xu\u1ED1ng v\xE0 m\u1ECDi sinh v\u1EADt
        m\u1EA5t \u0111i kh\u1EA3 n\u0103ng c\u1EA3m nh\u1EADn \xE2m nh\u1EA1c, Pulse
        Runner v\u1EABn c\xF2n nghe \u0111\u01B0\u1EE3c m\u1ED9t nh\u1ECBp \u0111\u1EADp
        y\u1EBFu \u1EDBt c\xF2n s\xF3t l\u1EA1i trong l\u1ED3ng ng\u1EF1c m\xECnh.\r\n\r\nKh\xF4ng
        ai bi\u1EBFt t\u1EA1i sao nh\u1ECBp \u0111\xF3 v\u1EABn c\xF2n. C\xF3 l\u1EBD
        v\xEC c\u1EADu qu\xE1 nh\u1ECF \u2014 ch\u01B0a k\u1ECBp h\u1ECDc c\xE1ch
        \xEDch k\u1EF7.\r\n\r\nM\u1ED7i b\u01B0\u1EDBc ch\u1EA1y c\u1EE7a Pulse Runner
        l\xE0m m\u1EB7t \u0111\u1EA5t b\u1EEBng l\xEAn m\u1ED9t n\u1ED1t nh\u1EA1c,
        k\xE9o l\u1EA1i ch\xFAt m\xE0u s\u1EAFc trong th\u1EBF gi\u1EDBi tro x\xE1m.
        C\u1EADu kh\xF4ng ch\u1EA1y \u0111\u1EC3 tho\xE1t kh\u1ECFi s\u1EF1 t\u0129nh
        l\u1EB7ng \u2014 c\u1EADu ch\u1EA1y \u0111\u1EC3 \u0111\u1EADp v\u1EE1 n\xF3."
      quoteText: "\"Th\u1EBF gi\u1EDBi ngo\xE0i kia \u0111ang ch\u1EBFt d\u1EA7n
        trong im l\u1EB7ng. D\xF9 nh\u1ECBp \u0111\u1EADp c\u1EE7a t\xF4i nh\u1ECF
        b\xE9, t\xF4i v\u1EABn s\u1EBD d\xF9ng n\xF3 \u0111\u1EC3 \u0111\xE1nh th\u1EE9c
        m\u1ECDi ng\u01B0\u1EDDi!\""
      quoteColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
    skill:
      skillName: Standard
      energyCost: 1
      energyFill: {fileID: 1479237582}
      energyFillColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
      howToUse: "Ch\u1EC9 s\u1ED1 c\u01A1 b\u1EA3n ti\xEAu chu\u1EA9n \u2014 kh\xF4ng
        c\xF3 hi\u1EC7u \u1EE9ng \u0111\u1EB7c bi\u1EC7t. C\xE2n b\u1EB1ng t\u1ED1c
        \u0111\u1ED9, n\u0103ng l\u01B0\u1EE3ng v\xE0 \u0111i\u1EC1u khi\u1EC3n,
        ph\xF9 h\u1EE3p v\u1EDBi m\u1ECDi lo\u1EA1i m\xE0n ch\u01A1i."
      noteText: "Nh\xE2n v\u1EADt m\u1EB7c \u0111\u1ECBnh. Kh\xF4ng c\u1EA7n m\u1EDF
        kh\xF3a. \u0110i\u1EC3m kh\u1EDFi \u0111\u1EA7u l\xFD t\u01B0\u1EDFng \u0111\u1EC3
        l\xE0m quen c\u01A1 ch\u1EBF grid v\xE0 energy system."
      noteColor: {r: 1, g: 0.9215687, b: 0.015686275, a: 1}
  - characterName: RIFF
    traits: INTENSE RHYHM
    characterAnimator: {fileID: 0}
    nameColor: {r: 0.99215686, g: 1, b: 0.78039217, a: 0}
    titleColor: {r: 0.99215686, g: 1, b: 0.78039217, a: 1}
    traitsColor: {r: 1, g: 0.6666667, b: 0.33333334, a: 1}
    backgroundSprite: {fileID: 2638395065295414205, guid: 153733f2efc2c0d46bb119a4c851b815, type: 3}
    rotatingCircleSprite: {fileID: 9212586617721687871, guid: 98d88227e765011429ca5e72f17178a2, type: 3}
    profile:
      speedValue: 100
      speedTextColor: {r: 1, g: 0.6666667, b: 0.33333334, a: 1}
      progressFill: {fileID: 128680841}
      fillColor: {r: 0.9921569, g: 1, b: 0.7803922, a: 1}
    story:
      storyText: "Riff t\u1EEBng l\xE0 tay ch\u01A1i patin n\u1ED5i ti\u1EBFng nh\u1EA5t
        khu ph\u1ED1 \u2014 kh\xF4ng ph\u1EA3i v\xEC c\u1EADu gi\u1ECFi, m\xE0 v\xEC
        c\u1EADu kh\xF4ng bao gi\u1EDD d\u1EEBng l\u1EA1i.\r\n\r\nKhi The Silence
        x\xF3a s\u1EA1ch \xE2m thanh, Riff l\xE0 ng\u01B0\u1EDDi \u0111\u1EA7u ti\xEAn
        b\u1EAFt \u0111\u1EA7u g\xF5 nh\u1ECBp l\xEAn m\u1EB7t \u0111\u1EA5t b\u1EB1ng
        b\xE1nh xe patin \u2014 kh\xF4ng ph\u1EA3i v\xEC c\xF3 k\u1EBF ho\u1EA1ch,
        m\xE0 v\xEC c\u1EADu kh\xF4ng bi\u1EBFt l\xE0m g\xEC kh\xE1c ngo\xE0i vi\u1EC7c
        l\u0103n ti\u1EBFp.\r\n\r\nC\u1EADu gh\xE9t im l\u1EB7ng theo ngh\u0129a
        \u0111en nh\u1EA5t c\xF3 th\u1EC3."
      quoteText: "\"Ch\xE1n b\u1ECF m\u1EB9. B\u1EADt nh\u1EA1c l\xEAn \u0111i!\""
      quoteColor: {r: 1, g: 0.6666667, b: 0.33333334, a: 1}
    skill:
      skillName: 'Shred '
      energyCost: 2
      energyFill: {fileID: 1479237582}
      energyFillColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
      howToUse: "Th\u1EF1c hi\u1EC7n m\u1ED9t c\xFA Kickflip tung ra v\u1EC7t s\xF3ng
        \xE2m / s\u01A1n x\u1ECBt, ph\xE1 h\u1EE7y ngay l\u1EADp t\u1EE9c 1 ch\u01B0\u1EDBng
        ng\u1EA1i v\u1EADt ph\xEDa tr\u01B0\u1EDBc m\u1EB7t. Kh\xF4ng l\xE0m thay
        \u0111\u1ED5i v\u1ECB tr\xED h\xE0ng \u0111ang \u0111\u1EE9ng."
      noteText: "Hi\u1EC7u qu\u1EA3 nh\u1EA5t khi \u0111\u1ED1i m\u1EB7t v\u1EDBi
        ch\u01B0\u1EDBng ng\u1EA1i v\u1EADt \u0111\u01A1n l\u1EBB ch\u1EB7n ngang
        \u0111\u01B0\u1EDDng ch\u1EA1y. Kh\xF4ng ph\xE1 \u0111\u01B0\u1EE3c boss
        ho\u1EB7c c\u1EA5u tr\xFAc l\u1EDBn."
      noteColor: {r: 1, g: 0.6666667, b: 0.33333334, a: 1}
  - characterName: ARIA
    traits: FLOWING MELODY
    characterAnimator: {fileID: 0}
    nameColor: {r: 0.99215686, g: 0.9019608, b: 0.22745098, a: 0}
    titleColor: {r: 0.99215686, g: 0.9019608, b: 0.22745098, a: 1}
    traitsColor: {r: 1, g: 1, b: 1, a: 1}
    backgroundSprite: {fileID: -3893141973531030841, guid: 37ec3e572dbc88d4c89a8667e1a4684e, type: 3}
    rotatingCircleSprite: {fileID: 9212586617721687871, guid: a305a6a8dbcb92648b6f0ca243ee2e2f, type: 3}
    profile:
      speedValue: 50
      speedTextColor: {r: 1, g: 1, b: 1, a: 1}
      progressFill: {fileID: 128680841}
      fillColor: {r: 0.9921569, g: 0.90196085, b: 0.227451, a: 1}
    story:
      storyText: "Aria l\u1EDBn l\xEAn trong x\u01B0\u1EDFng s\u1EEDa loa c\u1EE7a
        cha \u2014 c\xF4 c\xF3 th\u1EC3 nh\u1EADn ra m\u1ED9t c\xE2y \u0111\xE0n
        l\u1EC7ch tune t\u1EEB c\xE1ch xa ba t\xF2a nh\xE0.\r\n\r\nKhi The Silence
        \u0111\u1EBFn, c\xF4 kh\xF4ng ho\u1EA3ng lo\u1EA1n. C\xF4 ng\u1ED3i xu\u1ED1ng
        s\xE0n x\u01B0\u1EDFng v\xE0 l\u1EAFng nghe th\u1EADt k\u1EF9 \u2014 v\u1EABn
        c\xF2n \u0111\xF3 m\u1ED9t giai \u0111i\u1EC7u r\u1EA5t nh\u1ECF, r\u1EA5t
        m\u1ECFng, nh\u01B0 ti\u1EBFng th\u1EDF h\u1EAFt ra cu\u1ED1i c\xF9ng.\r\n\r\nAria
        \u0111i theo ti\u1EBFng \u0111\xF3. C\xF4 kh\xF4ng ch\u1EA1y \u2014 c\xF4
        tr\xF4i."
      quoteText: "\"N\u1EBFu c\u1EADu l\u1EAFng nghe \u0111\u1EE7 im, c\u1EADu s\u1EBD
        nghe th\u1EA5y th\u1EBF gi\u1EDBi v\u1EABn \u0111ang h\xE1t nh\u1EB9 th\xF4i...\""
      quoteColor: {r: 0.99215686, g: 0.9019608, b: 0.22745098, a: 1}
    skill:
      skillName: 'Hover '
      energyCost: 1
      energyFill: {fileID: 1479237582}
      energyFillColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
      howToUse: "Gi\u1EEF ph\xEDm nh\u1EA3y \u0111\u1EC3 bay tr\xEAn kh\xF4ng th\xEAm
        1 nh\u1ECBp m\xE0 kh\xF4ng b\u1ECB r\u01A1i xu\u1ED1ng h\xE0ng. Aria m\u1EDF
        \xF4 \xE1nh s\xE1ng trong l\xFAc l\u01A1 l\u1EEDng, k\xE9o d\xE0i th\u1EDDi
        gian ph\xE1n \u0111o\xE1n ch\u01B0\u1EDBng ng\u1EA1i v\u1EADt."
      noteText: "L\xFD t\u01B0\u1EDFng cho c\xE1c \u0111o\u1EA1n nh\u1ECBp b\u1EA5t
        th\u01B0\u1EDDng ho\u1EB7c khi c\u1EA7n '\u0111\u1ECDc' m\xE0n ch\u01A1i
        tr\u01B0\u1EDBc khi \u0111\xE1p. Chi ph\xED n\u0103ng l\u01B0\u1EE3ng th\u1EA5p
        nh\u1EA5t trong roster."
      noteColor: {r: 0.9921569, g: 0.90196085, b: 0.227451, a: 1}
  - characterName: BAZE
    traits: DEEP BASS
    characterAnimator: {fileID: 0}
    nameColor: {r: 0.49019608, g: 1, b: 1, a: 0}
    titleColor: {r: 0.49019608, g: 1, b: 1, a: 1}
    traitsColor: {r: 0.49803922, g: 1, b: 0.4, a: 1}
    backgroundSprite: {fileID: 9212586617721687871, guid: 49b5ad1bd1144cc44b1bdaf5acdb9695, type: 3}
    rotatingCircleSprite: {fileID: 3532162408921733062, guid: df0902b09a1506a458bcffbdf46dc693, type: 3}
    profile:
      speedValue: 50
      speedTextColor: {r: 0.49803925, g: 1, b: 0.40000004, a: 1}
      progressFill: {fileID: 128680841}
      fillColor: {r: 0, g: 1, b: 1, a: 1}
    story:
      storyText: "Baze kh\xF4ng n\xF3i nhi\u1EC1u. C\u1EADu ta n\xF3i b\u1EB1ng bass.\r\n\r\nTr\u01B0\u1EDBc
        The Silence, Baze l\xE0 tay s\u1EA3n xu\u1EA5t nh\u1EA1c underground \u2014
        chuy\xEAn nh\u1EEFng b\u1EA3n beat th\u1EA5p \u0111\u1EBFn m\u1EE9c kh\xE1n
        gi\u1EA3 c\u1EA3m nh\u1EADn b\u1EB1ng l\u1ED3ng ng\u1EF1c ch\u1EE9 kh\xF4ng
        ph\u1EA3i tai.\r\n\r\nSau The Silence, c\u1EADu ph\xE1t hi\u1EC7n ra r\u1EB1ng
        nh\u1ECBp bass c\u1EE7a m\xECnh v\u1EABn c\xF2n \u2014 kh\xF4ng ph\u1EA3i
        \xE2m thanh, m\xE0 l\xE0 rung \u0111\u1ED9ng. V\xE0 rung \u0111\u1ED9ng th\xEC
        kh\xF4ng b\u1ECB t\u0129nh l\u1EB7ng d\u1EADp t\u1EAFt \u0111\u01B0\u1EE3c."
      quoteText: "\"Ng\u01B0\u01A1i kh\xF4ng nghe \u0111\u01B0\u1EE3c ta. Nh\u01B0ng
        ng\u01B0\u01A1i s\u1EBD c\u1EA3m nh\u1EADn \u0111\u01B0\u1EE3c ta.\""
      quoteColor: {r: 0.49019608, g: 1, b: 1, a: 1}
    skill:
      skillName: Stomp
      energyCost: 3
      energyFill: {fileID: 1479237582}
      energyFillColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
      howToUse: "Khi \u0111ang \u1EDF tr\xEAn kh\xF4ng, r\u01A1i c\u1EAFm th\u1EB3ng
        xu\u1ED1ng h\xE0ng d\u01B0\u1EDBi c\xF9ng ngay l\u1EADp t\u1EE9c. Khi ti\u1EBFp
        \u0111\u1EA5t t\u1EA1o ra Shockwave ph\xE1 h\u1EE7y to\xE0n b\u1ED9 gai nh\u1ECDn
        trong ph\u1EA1m vi ti\u1EBFp \u0111\u1EA5t."
      noteText: "B\u1ECF qua t\u1EA5t c\u1EA3 c\xE1c h\xE0ng gi\u1EEFa \u2014 teleport
        th\u1EB3ng xu\u1ED1ng \u0111\xE1y. Hi\u1EC7u qu\u1EA3 nh\u1EA5t khi k\u1EBFt
        h\u1EE3p v\u1EDBi \u0111\u1ECBa h\xECnh nhi\u1EC1u spike ph\xEDa d\u01B0\u1EDBi
        ho\u1EB7c sau Speed Portal."
      noteColor: {r: 0.4901961, g: 1, b: 1, a: 1}
  - characterName: CLEF
    traits: REBELLIOUS STYLE
    characterAnimator: {fileID: 0}
    nameColor: {r: 0.4745098, g: 0.92156863, b: 0.4627451, a: 0}
    titleColor: {r: 0.4745098, g: 0.92156863, b: 0.4627451, a: 1}
    traitsColor: {r: 0.8666667, g: 0.6, b: 1, a: 1}
    backgroundSprite: {fileID: 2638395065295414205, guid: 90a952ef4e8a5e848997ed41b8b59b41, type: 3}
    rotatingCircleSprite: {fileID: 9212586617721687871, guid: 30f05392767c6ff44a6da86573100b7e, type: 3}
    profile:
      speedValue: 75
      speedTextColor: {r: 0.47450984, g: 0.9215687, b: 0.46274513, a: 1}
      progressFill: {fileID: 128680841}
      fillColor: {r: 0.86666673, g: 0.6, b: 1, a: 1}
    story:
      storyText: "Clef kh\xF4ng quan t\xE2m \u0111\u1EBFn lu\u1EADt l\u1EC7 \u2014
        k\u1EC3 c\u1EA3 lu\u1EADt v\u1EADt l\xFD.\r\n\r\nC\xF4 l\xE0 ngh\u1EC7 s\u0129
        graffiti n\u1ED5i ti\u1EBFng nh\u1EA5t (v\xE0 b\u1ECB truy n\xE3 nhi\u1EC1u
        nh\u1EA5t) trong th\xE0nh ph\u1ED1. C\xE1c t\xE1c ph\u1EA9m c\u1EE7a c\xF4
        xu\u1EA5t hi\u1EC7n kh\u1EAFp n\u01A1i \u2014 tr\xEAn t\u01B0\u1EDDng, tr\xEAn
        tr\u1EA7n, \u0111\xF4i khi tr\xEAn c\u1EA3 \xF4 t\xF4 \u0111ang ch\u1EA1y.\r\n\r\nKhi
        The Silence \u0111\u1EBFn v\xE0 x\xF3a s\u1EA1ch m\xE0u s\u1EAFc kh\u1ECFi
        th\u1EBF gi\u1EDBi, Clef ch\u1EC9 nh\xFAn vai v\xE0 l\xF4i th\xEAm m\u1ED9t
        b\xECnh x\u1ECBt ra. C\xF4 kh\xF4ng ch\u1EA1y tr\u1ED1n kh\u1ECFi nguy hi\u1EC3m
        \u2014 c\xF4 xuy\xEAn th\u1EB3ng qua n\xF3."
      quoteText: '"Rules? I only follow the beat."'
      quoteColor: {r: 0.4745098, g: 0.92156863, b: 0.4627451, a: 1}
    skill:
      skillName: Phase
      energyCost: 4
      energyFill: {fileID: 1479237582}
      energyFillColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
      howToUse: "B\u1ECDc b\u1EA3n th\xE2n trong l\xE1 ch\u1EAFn s\u01A1n x\u1ECBt
        \u2014 bong b\xF3ng k\u1EB9o cao su ph\xE1t s\xE1ng \u2014 cho ph\xE9p \u0111i
        xuy\xEAn qua 1 ch\u01B0\u1EDBng ng\u1EA1i v\u1EADt m\xE0 kh\xF4ng ch\u1EBFt.
        L\xE1 ch\u1EAFn bi\u1EBFn m\u1EA5t sau khi h\u1EA5p th\u1EE5 1 va ch\u1EA1m."
      noteText: "Chi ph\xED n\u0103ng l\u01B0\u1EE3ng cao nh\u1EA5t trong roster
        \u2014 ti\xEAu hao to\xE0n b\u1ED9 4 thanh. C\u1EA7n c\xE2n nh\u1EAFc k\u1EF9
        tr\u01B0\u1EDBc khi d\xF9ng. Kh\xF4ng t\xEDch l\u0169y \u2014 ch\u1EC9 xuy\xEAn
        \u0111\u01B0\u1EE3c 1 v\u1EADt th\u1EC3 m\u1ED7i l\u1EA7n k\xEDch ho\u1EA1t."
      noteColor: {r: 0.47450984, g: 0.9215687, b: 0.46274513, a: 1}

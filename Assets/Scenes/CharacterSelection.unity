  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Khi The Silence \u1EADp xu\u1ED1ng v\xE0 m\u1ECDi sinh v\u1EADt m\u1EA5t
    \u0111i kh\u1EA3 n\u0103ng c\u1EA3m nh\u1EADn \xE2m nh\u1EA1c, Pulse Runner v\u1EABn
    c\xF2n nghe \u0111\u01B0\u1EE3c m\u1ED9t nh\u1ECBp \u0111\u1EADp y\u1EBFu \u1EDBt
    c\xF2n s\xF3t l\u1EA1i trong l\u1ED3ng ng\u1EF1c m\xECnh.\r\n\r\nKh\xF4ng ai
    bi\u1EBFt t\u1EA1i sao nh\u1ECBp \u0111\xF3 v\u1EABn c\xF2n. C\xF3 l\u1EBD v\xEC
    c\u1EADu qu\xE1 nh\u1ECF \u2014 ch\u01B0a k\u1ECBp h\u1ECDc c\xE1ch \xEDch k\u1EF7.\r\n\r\nM\u1ED7i
    b\u01B0\u1EDBc ch\u1EA1y c\u1EE7a Pulse Runner l\xE0m m\u1EB7t \u0111\u1EA5t
    b\u1EEBng l\xEAn m\u1ED9t n\u1ED1t nh\u1EA1c, k\xE9o l\u1EA1i ch\xFAt m\xE0u
    s\u1EAFc trong th\u1EBF gi\u1EDBi tro x\xE1m. C\u1EADu kh\xF4ng ch\u1EA1y \u0111\u1EC3
    tho\xE1t kh\u1ECFi s\u1EF1 t\u0129nh l\u1EB7ng \u2014 c\u1EADu ch\u1EA1y \u0111\u1EC3
    \u0111\u1EADp v\u1EE1 n\xF3."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
